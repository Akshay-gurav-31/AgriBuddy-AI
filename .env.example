# Flask Configuration
FLASK_SECRET_KEY="your-secret-key-here"
PORT=5000

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url-here"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# APIs
GEMINI_API_KEY="your-gemini-api-key-here"
OPENWEATHER_API_KEY="your-openweather-api-key-here"

# Community security controls
# Set true to encrypt community message/image payloads before DB save.
COMMUNITY_ENCRYPTION_ENABLED="true"
# Optional: Fernet key (recommended). If empty, key is derived from FLASK_SECRET_KEY.
# Generate with Python:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COMMUNITY_ENCRYPTION_KEY=""

# Auto-delete old community posts
# Set true to delete old posts automatically on read/write operations.
COMMUNITY_AUTO_DELETE_ENABLED="false"
COMMUNITY_AUTO_DELETE_HOURS="24"
